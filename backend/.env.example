# Copy to .env and fill in real values. Never commit .env.

# --- Postgres (consumed by docker-compose) ---
POSTGRES_USER=airport
POSTGRES_PASSWORD=change-me-to-something-random
POSTGRES_DB=airport_ops

# Host port for the database. 5432 is the conventional default; change it if you
# already run PostgreSQL locally, or `docker compose up` fails with
# "Bind for 0.0.0.0:5432 failed: port is already allocated".
# Whatever you set here must match the port in AIRPORT_DATABASE_URL below.
POSTGRES_PORT=5433
API_PORT=8000

# --- Application ---
AIRPORT_ENVIRONMENT=local
AIRPORT_DEBUG=true

# Host-side URL, used by tests and by run_local.py. The port must match
# POSTGRES_PORT above. Inside docker-compose the API ignores this and connects to
# the "db" service on the container network instead.
AIRPORT_DATABASE_URL=postgresql+psycopg://airport:change-me-to-something-random@localhost:5433/airport_ops

# Must be at least 32 characters. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AIRPORT_JWT_SECRET=

AIRPORT_ACCESS_TOKEN_TTL_MINUTES=30
AIRPORT_REFRESH_TOKEN_TTL_DAYS=7
